  case $(menu "Install" "¾░©î  Theme\n´Ç¥  Background\n¯ÖÖ  Font") in
  *Theme*) present_terminal omarchy-theme-install ;;
  *Background*) nautilus ~/.config/omarchy/current/theme/backgrounds ;;
