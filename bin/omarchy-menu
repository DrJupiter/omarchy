  case $(menu "Branch" "master\ndev" "" "$(omarchy-version-branch)") in
  *master*) present_terminal "omarchy-update-branch master" ;;
  *dev*) present_terminal "omarchy-update-branch dev" ;;
  *) show_update_menu ;;
  esac
}
